class Solution {
    public int[] shuffle(int[] nums, int n) {
        // Create a new array of the same size to store the result
        int[] result = new int[2 * n];
        
        // This pointer helps us place elements into the result array
        int index = 0;
        
        for (int i = 0; i < n; i++) {
            result[index] = nums[i];       // Add the x element (first half)
            index++;                       // Move to the next spot
            
            result[index] = nums[i + n];   // Add the y element (second half)
            index++;                       // Move to the next spot
        }
        
        return result;
    }
}
